<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Ladla Pub & Restaurant – Puttalam</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Lora:ital@0;1&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --ink: #12100e; --parchment: #f5ead8; --amber: #c8780a;
      --gold: #e8a820; --cream: #fdf6e8; --dark: #1e1208; --muted: #7a6248;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--cream); color: var(--ink); font-family: 'Lora', serif; overflow-x: hidden; }

    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      background: var(--dark); border-bottom: 2px solid var(--amber);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2.5rem; height: 60px;
    }
    nav .logo { font-family: 'Playfair Display', serif; color: var(--gold); font-size: 1.2rem; }
    nav ul { list-style: none; display: flex; gap: 2rem; }
    nav ul a { color: var(--parchment); text-decoration: none; font-size: .85rem; letter-spacing: .08em; text-transform: uppercase; transition: color .25s; }
    nav ul a:hover { color: var(--gold); }

    #hero {
      min-height: 100vh;
      background:
        radial-gradient(ellipse at 65% 35%, rgba(200,120,10,.2) 0%, transparent 55%),
        radial-gradient(ellipse at 20% 75%, rgba(45,74,30,.25) 0%, transparent 50%),
        linear-gradient(150deg, #1e1208 0%, #12100e 50%, #2a1a06 100%);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center; padding: 6rem 2rem 4rem; position: relative; overflow: hidden;
    }
    #hero::before {
      content: ''; position: absolute; inset: 0;
      background-image: radial-gradient(circle, rgba(232,168,32,.07) 1px, transparent 1px);
      background-size: 38px 38px; pointer-events: none;
    }
    .hero-badge {
      display: inline-block; border: 1px solid var(--amber); color: var(--amber);
      font-size: .72rem; letter-spacing: .2em; text-transform: uppercase;
      padding: .4rem 1.3rem; border-radius: 2px; margin-bottom: 1.8rem;
      animation: fadeUp .8s ease both;
    }
    #hero h1 {
      font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 8vw, 6rem);
      color: var(--parchment); line-height: 1.05; animation: fadeUp .9s .1s ease both;
    }
    #hero h1 em { color: var(--gold); font-style: italic; display: block; }
    #hero p { margin-top: 1.4rem; color: var(--muted); font-size: 1.05rem; max-width: 440px; line-height: 1.7; animation: fadeUp 1s .2s ease both; }
    .hero-cta { margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; animation: fadeUp 1s .3s ease both; }
    .btn { display: inline-block; padding: .75rem 2rem; font-family: 'Lora', serif; font-size: .9rem; letter-spacing: .06em; text-decoration: none; border-radius: 2px; transition: all .25s; cursor: pointer; }
    .btn-primary { background: var(--amber); color: var(--cream); border: 2px solid var(--amber); }
    .btn-primary:hover { background: var(--gold); border-color: var(--gold); }
    .btn-outline { background: transparent; color: var(--parchment); border: 2px solid var(--muted); }
    .btn-outline:hover { border-color: var(--parchment); }

    section { padding: 5rem 2rem; }
    .section-inner { max-width: 900px; margin: 0 auto; }
    .section-label { font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: var(--amber); margin-bottom: .6rem; }
    .section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--dark); margin-bottom: 1.2rem; line-height: 1.2; }
    .divider { width: 60px; height: 2px; background: var(--amber); margin: 1.2rem 0 2rem; }

    #about {
      background: var(--parchment);
      position: relative;
      overflow: hidden;
    }
    .about-bg { position: absolute; inset: 0; z-index: 0; }
    .about-bg-slide {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: center;
      opacity: 0;
      transition: opacity 2s ease-in-out;
    }
    .about-bg-slide.active { opacity: 1; }
    .about-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(245,234,216,.92) 0%, rgba(245,234,216,.82) 50%, rgba(245,234,216,.72) 100%);
      z-index: 1;
    }
    #about .section-inner { position: relative; z-index: 2; }
    #about p { font-size: 1.05rem; line-height: 1.85; color: var(--dark); max-width: 640px; }
    #about p + p { margin-top: 1rem; }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-top: 2.5rem; }
    .about-stat { background: var(--cream); border-left: 3px solid var(--amber); padding: 1.2rem 1.5rem; }
    .about-stat strong { display: block; font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--amber); margin-bottom: .3rem; }
    .about-stat span { font-size: .88rem; color: var(--muted); }

    #menu { background: var(--cream); }
    .menu-tabs { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .tab-btn { padding: .5rem 1.3rem; border: 1px solid var(--amber); background: transparent; color: var(--amber); font-family: 'Lora', serif; font-size: .85rem; letter-spacing: .06em; cursor: pointer; border-radius: 2px; transition: all .2s; }
    .tab-btn.active, .tab-btn:hover { background: var(--amber); color: var(--cream); }
    .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.2rem; }
    .menu-item { background: var(--parchment); border: 1px solid rgba(200,120,10,.2); padding: 1.2rem 1.4rem; border-radius: 3px; display: flex; flex-direction: column; gap: .4rem; transition: box-shadow .2s; }
    .menu-item:hover { box-shadow: 0 4px 20px rgba(200,120,10,.15); }
    .menu-item-top { display: flex; justify-content: space-between; align-items: baseline; }
    .menu-item h4 { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: var(--dark); }
    .menu-item .price { color: var(--amber); font-size: .95rem; font-weight: bold; white-space: nowrap; }
    .menu-item p { font-size: .82rem; color: var(--muted); font-style: italic; line-height: 1.5; }
    .menu-panel { display: none; }
    .menu-panel.active { display: block; }
    .menu-note { margin-top: 1.5rem; font-size: .85rem; color: var(--muted); font-style: italic; }

    #hours { background: var(--dark); }
    #hours .section-title { color: var(--parchment); }
    #hours .section-label { color: var(--gold); }
    .hours-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem; }
    .hours-card { background: rgba(255,255,255,.05); border: 1px solid rgba(232,168,32,.2); padding: 1.3rem 1.5rem; border-radius: 3px; }
    .hours-card .day { font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--gold); margin-bottom: .4rem; }
    .hours-card .time { font-size: 1.05rem; color: var(--parchment); }
    .hours-note { margin-top: 1.8rem; font-size: .85rem; color: var(--muted); font-style: italic; }

    #contact { background: var(--parchment); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
    .contact-info p { line-height: 1.8; color: var(--dark); margin-bottom: .5rem; }
    .contact-info strong { color: var(--amber); display: block; font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; margin-top: 1.4rem; margin-bottom: .3rem; }
    .map-embed { border-radius: 4px; overflow: hidden; border: 2px solid rgba(200,120,10,.3); height: 290px; }
    .map-embed iframe { width: 100%; height: 100%; border: 0; display: block; }

    footer { background: var(--ink); color: var(--muted); text-align: center; padding: 2rem; font-size: .82rem; letter-spacing: .06em; }
    footer span { color: var(--gold); }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

    /* ── SCROLL PROGRESS BAR ── */
    #scroll-progress {
      position: fixed; top: 0; left: 0; z-index: 200;
      height: 3px; width: 0%;
      background: linear-gradient(90deg, var(--amber), var(--gold));
      transition: width .1s linear;
      box-shadow: 0 0 8px rgba(232,168,32,.7);
    }

    /* ── REVEAL ANIMATIONS ── */
    .reveal         { opacity: 0; transform: translateY(40px);   transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1); }
    .reveal-left    { opacity: 0; transform: translateX(-50px);  transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1); }
    .reveal-right   { opacity: 0; transform: translateX(50px);   transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1); }
    .reveal-scale   { opacity: 0; transform: scale(.88);         transition: opacity .7s ease, transform .7s cubic-bezier(.34,1.56,.64,1); }
    .reveal.visible, .reveal-left.visible, .reveal-right.visible, .reveal-scale.visible {
      opacity: 1; transform: none;
    }
    /* stagger children inside a revealed parent */
    .stagger > * { opacity: 0; transform: translateY(30px); transition: opacity .6s cubic-bezier(.16,1,.3,1), transform .6s cubic-bezier(.16,1,.3,1); }
    .stagger.visible > *:nth-child(1) { opacity:1; transform:none; transition-delay:.05s; }
    .stagger.visible > *:nth-child(2) { opacity:1; transform:none; transition-delay:.15s; }
    .stagger.visible > *:nth-child(3) { opacity:1; transform:none; transition-delay:.25s; }
    .stagger.visible > *:nth-child(4) { opacity:1; transform:none; transition-delay:.35s; }
    .stagger.visible > *:nth-child(5) { opacity:1; transform:none; transition-delay:.45s; }
    .stagger.visible > *:nth-child(6) { opacity:1; transform:none; transition-delay:.55s; }
    .stagger.visible > *:nth-child(7) { opacity:1; transform:none; transition-delay:.65s; }

    /* ── ACTIVE NAV LINK ── */
    nav ul a.active { color: var(--gold); border-bottom: 2px solid var(--gold); padding-bottom: 2px; }

    /* ── PARALLAX HERO ── */
    .hero-parallax { will-change: transform; }

    /* ── SECTION DIVIDER WAVE ── */
    .wave-divider { display: block; width: 100%; overflow: hidden; line-height: 0; }
    .wave-divider svg { display: block; }

    /* ── SMOOTH HOVER ON CARDS ── */
    .menu-item   { transition: box-shadow .3s ease, transform .3s cubic-bezier(.34,1.56,.64,1); }
    .menu-item:hover { transform: translateY(-5px) scale(1.02); box-shadow: 0 12px 32px rgba(200,120,10,.2); }
    .hours-card  { transition: box-shadow .3s ease, transform .3s cubic-bezier(.34,1.56,.64,1), border-color .3s; }
    .hours-card:hover { transform: translateY(-4px); border-color: var(--gold); box-shadow: 0 8px 24px rgba(232,168,32,.2); }
    .about-stat  { transition: transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s; }
    .about-stat:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 8px 20px rgba(200,120,10,.15); }

    /* ── BEER LOGO ANIMATION ── */
    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(-2deg); }
      50%       { transform: translateY(-14px) rotate(2deg); }
    }
    @keyframes bubbleRise {
      0%   { transform: translateY(0) scale(1); opacity: .8; }
      100% { transform: translateY(-70px) scale(.2); opacity: 0; }
    }
    @keyframes foamPulse {
      0%, 100% { transform: scaleX(1); }
      50%       { transform: scaleX(1.07); }
    }
    @keyframes glowPulse {
      0%, 100% { filter: drop-shadow(0 0 8px rgba(232,168,32,.5)); }
      50%       { filter: drop-shadow(0 0 24px rgba(232,168,32,1)); }
    }
    @keyframes spinIn {
      from { opacity: 0; transform: rotate(-180deg) scale(.3); }
      to   { opacity: 1; transform: rotate(0deg) scale(1); }
    }
    .hero-logo-wrap {
      position: relative;
      margin: 0 auto 2rem;
      width: 150px;
      animation: fadeUp .6s ease both, float 4s ease-in-out 1s infinite;
    }
    .hero-logo-img {
      width: 150px; height: 150px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--amber);
      display: block;
      margin: 0 auto;
      animation: spinIn .8s cubic-bezier(.34,1.56,.64,1) both, glowPulse 3s ease-in-out 1s infinite;
    }
    /* Animated bubbles around logo */
    .logo-bubble {
      position: absolute;
      border-radius: 50%;
      background: rgba(232,168,32,.6);
      animation: bubbleRise ease-in infinite;
    }
    .lb1 { width:9px;  height:9px;  left:20px;  bottom:10px; animation-duration:1.8s; animation-delay:0s; }
    .lb2 { width:6px;  height:6px;  left:70px;  bottom:5px;  animation-duration:2.2s; animation-delay:.5s; }
    .lb3 { width:7px;  height:7px;  left:115px; bottom:15px; animation-duration:1.6s; animation-delay:1s; }
    .lb4 { width:5px;  height:5px;  left:45px;  bottom:0px;  animation-duration:2s;   animation-delay:1.4s; }
    /* Nav logo */
    .nav-logo-img {
      width: 34px; height: 34px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--amber);
      vertical-align: middle;
      margin-right: .5rem;
      animation: glowPulse 3s ease-in-out infinite;
    }

    @media (max-width: 640px) {
      nav ul { display: none; }
      .about-grid, .contact-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
